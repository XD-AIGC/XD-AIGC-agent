# 生产环境配置示例 — XD-AIGC-agent
#
# 部署到 L20_1 时：
#   1. cp 这个文件到 /etc/xd-aigc-agent/.env
#   2. 填入真实值（密钥从 1Password / Bitwarden / SSM 拿）
#   3. chmod 600 /etc/xd-aigc-agent/.env && chown root:root
#   4. systemctl restart xd-aigc-agent
#
# 安全提醒：
#   - 任何真值不能 commit 到 git（.gitignore 已挡 .env 但 .env.example.prod 允许）
#   - 永远不要让 Johnny 个人 LLM_API_KEY 在这里出现，必须用 bot 专属 token

# === 飞书 App（XD AIGC Toolbox） ===
FEISHU_APP_ID=cli_aa99420199f9dbd8
FEISHU_APP_SECRET=（飞书后台 → 应用 → 凭证与基础信息 → 应用凭证）

# === LLM（公司 LiteLLM Proxy） ===
LLM_BASE_URL=http://llm-proxy.tapsvc.com
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=（LiteLLM 后台为 bot 单发的 service token，不要用 Johnny 个人 key）

# === Redis（与 toolbox/gateway 共享 Redis 实例，新建 db 1 隔离 session） ===
REDIS_URL=redis://localhost:6379/1

# === Toolbox 后端（同机本地直连，不走 SSH 隧道） ===
TOOLBOX_BASE_URL=http://localhost:80

# === Mivo Hub（受控全局工具；只走 action=mcp 工具通道） ===
MIVO_ENDPOINT=https://aigc.xindong.com
# 与 toolbox 现有工具一致：用 MIVO_USER_SUB 换 Mivo session token
MIVO_USER_SUB=
MIVO_MCP_ALLOWED_TOOLS=list_tools,generate_image,submit_gen_image,submit_gen_3d_model,poll_result,poll_3d_result,convert_3d_model_format,segment_image,super_resolution_image,download_file

# === 运行模式 ===
ENV=production
AGENT_RUNTIME_DRY_RUN_TARGET=v1
AGENT_RUNTIME_DRY_RUN_V2_PERCENT=0
